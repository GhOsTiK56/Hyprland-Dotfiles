{
  "layer": "top",
  "position": "top",
  "mode": "dock",
  "exclusive": true,
  "passthrough": false,
  "gtk-layer-shell": true,
  "height": 0,
  "spacing": 3,
  "fixed-center": true,
  "ipc": true,
  "margin-top": 3,
  "margin-left": 8,
  "margin-right": 8,
  "modules-left": [
    "group/system",
    "hyprland/window"
  ],
  "modules-center": [
    "group/notify",
    "hyprland/workspaces",
    "custom/idle-inhibitor"
  ],
  "modules-right": [
    "custom/active-ip",
    "tray",
    "privacy",
    "battery",
    "custom/weather",
    "clock"
  ],
  // â”€â”€â”€ CORE â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  "hyprland/window": {
    "format": "{}",
    "icon": true,
    "icon-size": 14,
    "max-length": 60,
    "separate-outputs": true
  },
  "hyprland/workspaces": {
    "all-outputs": true,
    "warp-on-scroll": false,
    "sort-by-number": true,
    "show-special": true,
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "format": "{name} {windows}",
    "format-window-separator": " ",
    "window-rewrite-default": "",
    "window-rewrite": {
      "title<.*amazon.*>": "ًں›’",
      "title<.*reddit.*>": "ًں‘½",
      "class<firefox|org.mozilla.firefox|librewolf|floorp|mercury-browser|[Cc]achy-browser>": "َ°ˆ¹",
      "class<zen>": "َ°°·",
      "class<waterfox|waterfox-bin>": "َ°ˆ¹",
      "class<microsoft-edge>": "َ°‡©",
      "class<Chromium|Thorium|[Cc]hrome>": "َ°ٹ¯",
      "class<brave-browser>": "ًں¦پ",
      "class<tor browser>": "ًں§…",
      "class<firefox-developer-edition>": "ًں¦ٹ",
      "class<kitty|konsole|[Aa]lacritty>": "َ°„›",
      "class<com.mitchellh.ghostty>": "َ°„›",
      "class<org.wezfurlong.wezterm>": "َ°„›",
      "class<[Tt]hunderbird|[Tt]hunderbird-esr>": "َ°‡®",
      "title<.*gmail.*>": "َ°ٹ«",
      "class<[Tt]elegram-desktop|org.telegram.desktop>": "َ°”پ",
      "class<discord|discord-canary|[Ww]ebcord|[Vv]esktop|com.discordapp.Discord|dev.vencord.Vesktop>": "َ°™¯",
      "class<[Ss]ignal|signal-desktop|org.signal.Signal>": "َ°چ©",
      "title<.*whatsapp.*>": "َ°–£",
      "title<.*messenger.*>": "َ°ˆ¤",
      "title<.*Discord.*>": "َ°™¯",
      "title<.*ChatGPT.*>": "َ°ڑ©",
      "title<.*deepseek.*>": "َ°ڑ©",
      "class<subl>": "َ°…³",
      "class<slack>": "َ°’±",
      "class<mpv>": "َ°•§",
      "class<celluloid>": "َ°•§",
      "title<.*youtube.*>": "َ°—ƒ",
      "class<vlc>": "َ°•¼",
      "class<[Kk]denlive|org.kde.kdenlive>": "ًںژ¬",
      "title<.*cmus.*>": "َ°ژµ",
      "class<[Ss]potify>": "َ°“‡",
      "class<virt-manager>": "َ°چ¹",
      "class<virtualbox manager>": "ًں’½",
      "class<remmina|org.remmina.Remmina>": "ًں–¥ï¸ڈ",
      "class<VSCode|code|code-url-handler|code-oss|codium|codium-url-handler|VSCodium>": "َ°¨‍",
      "class<dev.zed.Zed>": "َ°µپ",
      "title<.*github.*>": "َ°ٹ¤",
      "class<libreoffice-writer>": "َ°ˆ™",
      "class<libreoffice-startcenter>": "َ°ڈ†",
      "class<libreoffice-calc>": "َ±“ں",
      "title<.*nvim ~.*>": "َ±ƒ•",
      "title<.*nvim.*>": "َ±ƒ•",
      "title<.*vim.*>": "َ±ƒ•",
      "title<.*figma.*>": "َ°”¦",
      "class<jetbrains-idea>": "َ±…ں",
      "class<obs|com.obsproject.Studio>": "َ°‘‹",
      "class<[Pp]avucontrol|org.pulseaudio.pavucontrol>": "َ±،«",
      "class<steam>": "َ°““",
      "class<thunar|nemo>": "َ°‌°",
      "class<dolphin>": "َ°‰‹",
      "class<obsidian>": "َ°ژ•",
      "class<Gparted>": "َ°‹ٹ",
      "class<gimp>": "َ°ڈ؛",
      "class<nwg-look>": "َ°”ژ"
    },
    "persistent-workspaces": {
      "*": 1
    }
  },
  "custom/control-center": {
    "format": "َ°‚ڑ {}",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "return-type": "json",
    "tooltip-format": "Notifiche: {}\nLeft: apri آ· Right: DND",
    "escape": true
  },
  "tray": {
    "icon-size": 16,
    "spacing": 8
  },
  "clock": {
    "format": "{:%b%e %H:%M}",
    "interval": 60,
    "tooltip-format": "<tt>{calendar}</tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#c6a0f6'><b>{}</b></span>",
        "weekdays": "<span color='#a5adcb'><b>{}</b></span>",
        "today": "<span color='#f5bde6'><b>{}</b></span>",
        "days": "<span color='#cad3f5'>{}</span>"
      }
    }
  },
  // â”€â”€â”€ SYSTEM â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  "group/system": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "children-class": "custom-temp",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/temp",
      "cpu",
      "memory"
    ]
  },
  "cpu": {
    "interval": 5,
    "format": "َ°چ› {usage}%",
    "tooltip": false
  },
  "memory": {
    "interval": 10,
    "format": "َ°¾† {used:0.1f}G",
    "tooltip-format": "{used:0.1f}G / {total:0.1f}G ({percentage}%)"
  },
  "custom/temp": {
    "format": "{}",
    "exec": "~/.config/waybar/themes/catppuccin/scripts/temp.sh",
    "interval": 5,
    "return-type": "json",
    "tooltip": true
  },
  // â”€â”€â”€ NOTIFY + THEME â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  "group/notify": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "children-class": "theme-btn",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/control-center",
      "custom/theme-macchiato",
      "custom/theme-hacker"
    ]
  },
  // â”€â”€â”€ POWER â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon} {percent}%",
    "format-icons": [
      "",
      "",
      "",
      "",
      ""
    ],
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-",
    "tooltip-format": "Brightness: {percent}%"
  },
  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 20
    },
    "format": "{icon} {capacity}%",
    "format-charging": " {capacity}%",
    "format-plugged": " {capacity}%",
    "format-alt": "{time} {icon}",
    "format-icons": [
      "َ°‚ƒ",
      "َ°پ؛",
      "َ°پ»",
      "َ°پ¼",
      "َ°پ½",
      "َ°پ¾",
      "َ°پ؟",
      "َ°‚€",
      "َ°‚پ",
      "َ°‚‚",
      "َ°پ¹"
    ],
    "tooltip-format": "{capacity}% ({timeTo})"
  },
  // â”€â”€â”€ STATUS (visibili solo se rilevanti) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  "privacy": {
    "icon-size": 14,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": true,
        "tooltip-icon-size": 24
      },
      {
        "type": "audio-in",
        "tooltip": true
      },
      {
        "type": "audio-out",
        "tooltip": false
      }
    ]
  },
  "custom/vpn": {
    "format": "{}",
    "exec": "~/.config/waybar/themes/catppuccin/scripts/vpn-status.sh",
    "interval": 10,
    "tooltip": false,
    "hide-empty-text": true
  },
  "custom/active-ip": {
    "exec": "~/.config/waybar/themes/catppuccin/scripts/active-ip.sh",
    "interval": 10,
    "format": "{}",
    "tooltip": false,
    "hide-empty-text": true
  },
  "custom/weather": {
    "format": "{}",
    "exec": "~/.config/waybar/themes/catppuccin/scripts/weather.sh",
    "interval": 1800,
    "return-type": "json",
    "tooltip": true,
    "hide-empty-text": true
  }
}